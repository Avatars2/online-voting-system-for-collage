{
  "name": "ovs-backend",
  "version": "0.1.0",
  "private": true,
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed/seed.js",
    "add-admin": "node seed/addAdmin.js",
    "setup-env": "node setup-secure-env.js > .env",
    "check-env": "node -e \"console.log('✅ JWT_SECRET:', process.env.JWT_SECRET ? 'SET' : 'NOT SET'); console.log('✅ JWT_SECRET length:', process.env.JWT_SECRET?.length || 0, 'characters');\"",
