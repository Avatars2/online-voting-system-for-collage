{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "env": {
    "VITE_API_URL": "https://online-voting-system-for-collage-wk.vercel.app/api",
    "VITE_WS_URL": "wss://online-voting-system-for-collage-wk.vercel.app",
    "VITE_APP_NAME": "Online Voting System",
    "VITE_APP_VERSION": "1.0.0",
    "VITE_FRONTEND_URL": "https://online-voting-system-for-collage.vercel.app"
  },
  "functions": {
    "dist/**/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
